---
// src/components/Experience.astro  (mirrors app/components/Experience.js)
const experienceData = [
  {
    title: 'Senior Service Desk Analyst',
    company: 'Ricoh Europe',
    duration: 'Apr 2025 – Present',
    responsibilities: [
      'Design, implement, and manage cloud-based solutions and hybrid identities using Microsoft Azure AD and Microsoft 365 (Exchange Online, SharePoint).',
      'Develop and execute PowerShell and Python automation scripts to optimise administrative tasks for Azure and M365.',
      'Ensure security and compliance by implementing policies via Microsoft Defender and managing access through IAM/RBAC.',
      'Generated and analysed weekly/monthly performance metrics reports using PowerBI, tracking FCR and ticket volume trends.',
      'Developed and maintained knowledge base articles, reducing repeat incidents by 25% and improving first-call resolution rates.',
      'Mentored and provided guidance to junior support staff on complex technical issues.',
    ],
  },
  {
    title: 'Learning Opportunity: Automation Engineering',
    company: 'Ricoh Europe',
    duration: 'Sep 2025 – Present',
    responsibilities: [
      'Developing proficiency in automated workflows using PowerShell, Python, and JavaScript to enhance service delivery.',
      'Building practical knowledge of CI/CD pipelines via GitHub and Azure DevOps projects.',
      'Gaining hands-on experience with the ServiceNow platform, workflow triggers, and enterprise integrations.',
      'Conducting root cause analysis on recurring issues and contributing automation solutions to reduce manual effort.',
      'Creating and maintaining technical documentation for automation scripts and recovery protocols.',
    ],
  },
  {
    title: 'IT Support Analyst',
    company: 'Ricoh South Africa',
    duration: 'Jun 2021 – Mar 2025',
    responsibilities: [
      'Provided Tier I support to 1,000+ users across major SaaS platforms.',
      'Managed account access, permissions, and deployments via Active Directory, Azure AD, and Google Workspace.',
      'Reduced access issues by improving VPN/networking support and documentation.',
      'Contributed to security posture by managing endpoint security tools and enforcing access controls.',
      'Administered Microsoft licensing and endpoint security.',
    ],
  },
  {
    title: 'Human Resources Administrator',
    company: 'Ricoh South Africa',
    duration: 'May 2018 – May 2021',
    responsibilities: [
      'Handled onboarding/offboarding, HR data management, and employee case resolution.',
      'Coordinated benefits, payroll support, and disability accommodations.',
      'Monitored HR metrics and reported trends to leadership.',
      'Delivered core HR admin functions including SuccessFactors updates and audit compliance.',
    ],
  },
  {
    title: 'Learnership',
    company: 'Altron People Solutions',
    duration: 'Jan 2016 – Apr 2018',
    responsibilities: [
      'Developed a professional foundation in written and verbal communication, administrative precision, and customer-oriented support.',
      'Gained early exposure to workplace procedures, confidentiality, and service delivery in a corporate environment.',
    ],
  },
];
---

<section id="experience" class="section">
  <h2>Work Experience</h2>
  <div class="timeline">
    {experienceData.map((exp, i) => (
      <div class="timeline-item" style={`animation-delay: ${(i * 0.2).toFixed(1)}s`}>
        <h3>{exp.title}</h3>
        <p class="company">{exp.company}</p>
        <span class="duration">{exp.duration}</span>
        <ul class="responsibilities">
          {exp.responsibilities.map((resp) => (
            <li>{resp}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<script>
  const section = document.getElementById('experience')!;
  const items = section.querySelectorAll('.timeline-item');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  observer.observe(section);
  items.forEach((item) => observer.observe(item));
</script>