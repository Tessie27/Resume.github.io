---
// src/components/SocialLinks.astro  (mirrors app/components/SocialLinks.js)
---

<div class="social-section">
  <div class="resume-section">
    <button class="btn resume-btn" id="resume-btn" aria-label="Download Resume">
      <span>Download Resume</span>
      <i class="fas fa-download ml-2"></i>
    </button>
  </div>

  <div class="social-links">
    <a
      href="https://www.linkedin.com/in/letezz-khan-722397159/"
      class="social-icon"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn Profile"
    >
      <i class="fab fa-linkedin-in"></i>
    </a>
    <a
      href="https://github.com/Tessie27"
      class="social-icon"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub Profile"
    >
      <i class="fab fa-github"></i>
    </a>
    <a
      href="mailto:letezzkhan@gmail.com"
      class="social-icon"
      aria-label="Send Email"
    >
      <i class="fas fa-envelope"></i>
    </a>
  </div>
</div>

<script>
  document.getElementById('resume-btn')!.addEventListener('click', () => {
    const link = document.createElement('a');
    link.href = '/Resume.pdf';       // matches public/Resume.pdf exactly
    link.download = 'Resume.pdf';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });
</script>